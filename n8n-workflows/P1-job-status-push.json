        },
        "options": {}
      },
      "id": "p1-fetch",
      "name": "Fetch Job from Supabase",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [-656, 112],
      "credentials": {
        "httpHeaderAuth": {
          "id": "l66cV4Gj1L3T6MjJ",
          "name": "Strapi API Token"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "// Map Supabase job to Sheet columns\nconst job = $input.first().json[0] || $input.first().json;\n\nconst autoQa = job.auto_qa_passed === true ? 'PASSED' : \n               job.auto_qa_passed === false ? 'FLAGGED' : '';\n\nlet autoQaDetails = '';\nif (job.auto_qa_results) {\n  const failed = Object.entries(job.auto_qa_results)\n    .filter(([k, v]) => !v.passed)\n    .map(([k, v]) => `${k}: ${v.details}`);\n  if (failed.length > 0) autoQaDetails = ` (${failed.join('; ')})`;\n}\n\nreturn [{\n  json: {\n    'Job ID': job.id,\n    'Status': job.status,\n    'Brief Summary': job.brief_summary || '',\n    'Hook Text': job.hook_text || '',\n    'CTA Text': job.cta_text || '',\n    'Template': job.template_id || '',\n    'Preview URL': job.preview_url || '',\n    'Auto QA': autoQa + autoQaDetails,\n    'Video Type': job.video_type || '',\n    'Created At': job.created_at,\n    'Completed At': job.completed_at || '',\n    'Row Status': 'OK'\n  }\n}];"
      },
      "id": "p1-map",
      "name": "Map to Sheet Columns",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [-448, 112]
    },
    {
