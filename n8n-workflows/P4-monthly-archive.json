      },
      "id": "p4-trigger",
      "name": "1st of Month at 2am",
      "type": "n8n-nodes-base.scheduleTrigger",
      "typeVersion": 1.2,
      "position": [-880, 112],
      "notes": "Runs on the 1st of every month at 2:00 AM"
    },
    {
      "parameters": {
        "authentication": "serviceAccount",
        "documentId": {
